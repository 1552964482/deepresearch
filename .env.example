# ---- Mimo (xiaomi) primary backend ----
MIMO_API_KEY=tp-xxx
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro

# Numbered slots are picked up by MimoPool for multi-key load balancing.
OPENAI_API_KEY1=tp-xxx
OPENAI_API_KEY2=tp-xxx
OPENAI_API_KEY3=tp-xxx
OPENAI_API_KEY4=tp-xxx
OPENAI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
OPENAI_MODEL=mimo-v2.5-pro

# Rate limits (per key)
MIMO_RPM_PER_KEY=100
MIMO_SAFE_CONCURRENCY_PER_KEY=4

# ---- Independent judge model (must be different family) ----
JUDGE_API_KEY=sk-xxx
JUDGE_BASE_URL=https://api.aveve.xyz/v1
JUDGE_MODEL=gpt-5.4
JUDGE_CONCURRENCY=4
JUDGE_N_SAMPLES=3

LOG_LEVEL=INFO
